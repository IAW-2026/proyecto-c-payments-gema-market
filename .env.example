NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR..."
MP_ACCESS_TOKEN="APP_USR..."
APP_URL="https://""
SELLER_APP_URL="https"
BUYER_APP_URL="https"
SHIPPING_APP_URL="https"
