// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model Usuario {
  id            String   @id @db.VarChar(50)
  clerkUserId   String   @unique @map("clerk_user_id") @db.VarChar(255)
  email         String?  @db.VarChar(255)
  fullName      String?  @map("full_name") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  mpUserId      String?  @map("mp_user_id") @db.VarChar(255)
  @@map("usuario")
}

model OrdenDePago {
  id              String   @id @db.VarChar(50)
  buyerId         String   @map("buyer_id") @db.VarChar(50)
  orders          Json     @map("orders")
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  fee             Decimal  @map("fee") @db.Decimal(12, 2)
  currency        String   @db.VarChar(3)
  status          String   @db.VarChar(50)
  mpPreferenceId  String?  @map("mp_preference_id") @db.VarChar(255)
  mpPaymentId     String?  @map("mp_payment_id") @db.VarChar(255)
  mpStatusDetail  String?  @map("mp_status_detail") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")
  paidAt          DateTime? @map("paid_at")

  transacciones   Transaccion[]

  @@map("orden_de_pago")
}

model Transaccion {
  id           String      @id @db.VarChar(50)
  paymentId    String      @map("payment_id") @db.VarChar(50)
  eventType    String      @map("event_type") @db.VarChar(100)
  payloadJson  Json        @map("payload_json")
  receivedAt   DateTime    @default(now()) @map("received_at")
  
  ordenDePago  OrdenDePago @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("transaccion")
}


